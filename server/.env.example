# VocaReach Server Configuration
PORT=4000

# MongoDB URI for session persistence
MONGODB_URI=mongodb://127.0.0.1:27017/vocareach

# API Keys (Set to "mock" for local sandbox testing without credits)
OCEAN_API_KEY=mock_ocean_key
PROSPEO_API_KEY=mock_prospeo_key
EAZYREACH_API_KEY=mock_eazyreach_key
BREVO_API_KEY=mock_brevo_key

# Sender Information
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME="Sales Engineering Team"
